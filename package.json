{
  "name": "flue-grc-engineer-demo",
  "version": "1.0.0",
  "description": "A Flue GRC engineer demo agent for Cloudflare Workers.",
  "type": "module",
  "scripts": {
    "dev": "npm run build && wrangler dev --config dist/wrangler.jsonc --env-file .env",
    "build": "flue build --target cloudflare && node scripts/patch-auth.mjs",
    "deploy": "npm run build && wrangler deploy --secrets-file .env"
  },
  "keywords": [
    "flue",
    "grc",
    "cloudflare-workers"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@cloudflare/sandbox": "^0.9.2",
    "@flue/sdk": "^0.3.5",
    "agents": "^0.12.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@flue/cli": "^0.3.5",
    "wrangler": "^4.87.0"
  }
}
