CLOUDFLARE_ACCOUNT_ID="your-account-id"
CLOUDFLARE_API_KEY="your-api-key"

# Auth options:
# - token: require Authorization: Bearer $GRC_AGENT_TOKEN
# - cloudflare-access: require Cloudflare Access identity headers
# - none: no app-level auth guard; only use for local/private experiments
GRC_AUTH_MODE="token"
GRC_AGENT_TOKEN="use-a-long-random-token"

# Optional when GRC_AUTH_MODE="cloudflare-access".
# Comma-separated list. Leave blank to allow any user who passes your Access policy.
GRC_ACCESS_ALLOWED_EMAILS=""
